{
  "name": "markdown",
  "version": "1.0.0",
  "main": "serve.cjs",
  "scripts": {
    "go": "pandoc -s -f markdown+fenced_divs --css=style.css --output=index.html index.md",
    "serve": "npx @11ty/eleventy --serve",
    "http": "node serve.cjs"
  },
  "keywords": [],
  "author": "MrBurst",
  "license": "ISC",
  "description": "Example of HTML generation from Markdown using Pandoc. Serving the generated HTML with Express.js.",
  "type": "module",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "express": "^5.2.1",
    "rehype": "^13.0.2"
  }
}
